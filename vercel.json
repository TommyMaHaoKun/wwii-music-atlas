{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/events", "destination": "/index.html" },
    { "source": "/countries", "destination": "/index.html" },
    { "source": "/sources", "destination": "/index.html" },
    { "source": "/training-data", "destination": "/index.html" },
    { "source": "/generate", "destination": "/index.html" }
  ]
}
